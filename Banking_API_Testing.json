{
  "info": {
    "name": "Banking_API_Testing",
    "_postman_id": "banking",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Login",
      "item": [
        {
          "name": "Valid Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/login"
            },
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"testuser\",\"password\":\"Password123\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response contains token', function () { pm.expect(pm.response.text()).to.include('token'); });",
                  "pm.test('Response time < 2000ms', function () { pm.expect(pm.response.responseTime).to.be.below(2000); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Invalid Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/login"
            },
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"testuser\",\"password\":\"WrongPassword\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Accounts",
      "item": [
        {
          "name": "Get Balance",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/accounts/1001/balance"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Invalid Account",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/accounts/9999/balance"
            }
          }
        }
      ]
    },
    {
      "name": "Transfer",
      "item": [
        {
          "name": "Successful Transfer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/transfer"
            },
            "body": {
              "mode": "raw",
              "raw": "{\"fromAccount\":\"1001\",\"toAccount\":\"1002\",\"amount\":500}"
            }
          }
        },
        {
          "name": "Insufficient Balance",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/transfer"
            },
            "body": {
              "mode": "raw",
              "raw": "{\"fromAccount\":\"1001\",\"toAccount\":\"1002\",\"amount\":100000}"
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://api.example-bank.com"
    },
    {
      "key": "token",
      "value": ""
    }
  ]
}